{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=AdmittoDB;Trusted_Connection=True;TrustServerCertificate=True",
    "Redis": "localhost:6379"
  },

  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "AdmittoApi",
    "Audience": "AdmittoApiUsers",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },

  "S3Settings": {
    "BucketName": "",
    "Region": "us-east-1",
    "AccessKey": "",
    "SecretKey": "",
    "BaseUrl": ""
  },

  "PaystackSettings": {
    "SecretKey": "",
    "BaseUrl": "https://api.paystack.co/"
  },

  "TicketmasterSettings": {
    "ApiKey": "",
    "BaseUrl": "https://app.ticketmaster.com/discovery/v2/"
  },

  "NotificationSettings": {
    "ApiKey": "",
    "BaseUrl": "https://api.sendgrid.com/v3/",
    "SenderEmail": "Admitto <admin@api.admitto.com>"
  },

  "FileSettings": {
    "UploadPath": "uploads",
    "BaseUrl": "https://localhost:7000"
  },

  "AllowedHosts": "*"
}
